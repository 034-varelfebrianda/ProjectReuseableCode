{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "esnext",
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "src/components/atoms",
    "src/components/molecules",
    "src/components/organism",
    "src/components/Home/home.tsx",
    "src/components/atoms",
    "src/data",
    "AvatarProfile.tsx",
    "ButtonMainContainer.tsx",
    "ComponentIcon.tsx",
    "Credit.tsx",
    "DemoCount.tsx",
    "IconButtons.tsx",
    "ListSidebar.tsx",
    "SearchIcon.tsx",
    "LogoBrand.tsx",
    "SearchText.tsx",
    "SeeDemosLink.tsx",
    "TextMainContainer.tsx",
    "ExploreCard.tsx",
    "ExploreComponents.tsx",
    "MainContain.tsx",
    "navbar.tsx",
    "Sidebar.tsx",
    "componentsData.ts",
    "ProductsService.ts"
  ]
}